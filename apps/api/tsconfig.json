{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "paths": {
      "@repo/salon-core": ["../../packages/salon-core/src/index.ts"],
      "@repo/salon-core/*": ["../../packages/salon-core/src/*"],
      "@repo/database": ["../../packages/database/src/index.ts"],
      "@repo/database/*": ["../../packages/database/src/*"],
      "@repo/auth": ["../../packages/auth/src/index.ts"],
      "@repo/auth/*": ["../../packages/auth/src/*"],
      "@repo/notifications": ["../../packages/notifications/src/index.ts"],
      "@repo/notifications/*": ["../../packages/notifications/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
