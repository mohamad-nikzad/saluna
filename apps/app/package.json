{
  "name": "@repo/app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "ROOT_ENV_FILES=.env.database.dev node ../../scripts/with-root-env.mjs next dev --port 3000",
    "dev:hono": "USE_HONO_API=1 ROOT_ENV_FILES=.env.database.dev node ../../scripts/with-root-env.mjs next dev --port 3000",
    "dev:lan": "ROOT_ENV_FILES=.env.database.dev node ../../scripts/with-root-env.mjs next dev --hostname 0.0.0.0 --port 3000",
    "build": "ROOT_ENV_FILES=.env.database.dev node ../../scripts/with-root-env.mjs next build",
    "start": "ROOT_ENV_FILES=.env.database.dev node ../../scripts/with-root-env.mjs next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test --config ../../playwright.config.ts",
    "boundaries": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@hookform/resolvers": "^3.9.1",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@repo/auth": "workspace:*",
    "@repo/brand-tokens": "workspace:*",
    "@repo/data-client": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/notifications": "workspace:*",
    "@repo/salon-core": "workspace:*",
    "@repo/ui": "workspace:*",
    "@vercel/analytics": "1.6.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "4.1.0",
    "drizzle-orm": "^0.39.3",
    "lucide-react": "^0.564.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-hook-form": "^7.54.1",
    "react-dom": "19.1.0",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/next-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "tailwindcss": "^4.2.2"
  }
}
