{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/with-root-env.mjs next dev --port 3001",
    "dev:local": "ROOT_ENV_FILES=.env.database.local node ../../scripts/with-root-env.mjs next dev --hostname 0.0.0.0 --port 3001",
    "build": "node ../../scripts/with-root-env.mjs next build",
    "start": "node ../../scripts/with-root-env.mjs next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "boundaries": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@repo/salon-core": "workspace:*",
    "lucide-react": "^0.564.0",
    "next": "16.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/next-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
