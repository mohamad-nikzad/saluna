{
  "name": "@repo/web",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node ../../scripts/with-root-env.mjs astro dev --port 3001",
    "build": "node ../../scripts/with-root-env.mjs astro build",
    "start": "HOST=0.0.0.0 PORT=3001 node ../../scripts/with-root-env.mjs node ./dist/server/entry.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "node ../../scripts/smoke-web.mjs",
    "preview": "node ../../scripts/with-root-env.mjs astro preview --port 3001",
    "lint": "eslint .",
    "typecheck": "astro check && tsc --project tsconfig.json --noEmit",
    "boundaries": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.2",
    "@astrojs/react": "^5.0.6",
    "@astrojs/sitemap": "^3.7.0",
    "@repo/api-client": "workspace:*",
    "@repo/brand": "workspace:*",
    "@repo/salon-core": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.4.2",
    "lucide-react": "^0.564.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "satori": "^0.18.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@astrojs/check": "^0.9.6",
    "eslint-plugin-astro": "^1.5.0",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.2"
  }
}
