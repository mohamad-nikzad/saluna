---
import { displayClass, toneClass, type ManagementArea } from '@/content/landing'

interface Props {
  managementAreas: ManagementArea[]
  requestFlow: { title: string; text: string }[]
  productSignals: { value: string; label: string }[]
  seoTopics: string[]
}

const { managementAreas, requestFlow, productSignals, seoTopics } = Astro.props
---

<section id="requests" class="relative px-5 py-20 sm:px-8 sm:py-24">
  <div
    class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start"
  >
    <div>
      <p class="text-sm font-extrabold text-[#9b3348]">تصویر کلی محصول</p>
      <h2
        class={`${displayClass} mt-3 text-3xl leading-tight text-[#3f2730] sm:text-5xl`}
      >
        همه چیز برای مدیریت روزانه سالن
      </h2>
      <p class="mt-5 text-base leading-8 text-[#6b4955]">
        سالونا امکانات اصلی سالن را کنار هم می‌آورد: تقویم، مشتری، خدمات، پرسنل،
        صفحه عمومی و مسیر درخواست نوبت. این محتوا هم برای مشتری سالن خواناست و
        هم برای موتورهای جست‌وجو دقیق و قابل فهم است.
      </p>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        {
          productSignals.map((signal) => (
            <div class="rounded-2xl border border-[#f3d5dd] bg-white/75 p-4">
              <p class="text-sm font-extrabold text-[#7a2a40]">
                {signal.value}
              </p>
              <p class="mt-2 text-xs leading-6 text-[#7b5b64]">
                {signal.label}
              </p>
            </div>
          ))
        }
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        {
          seoTopics.map((topic) => (
            <span class="rounded-full border border-[#f3d5dd] bg-white/70 px-3 py-1.5 text-xs font-bold text-[#7a2a40]">
              {topic}
            </span>
          ))
        }
      </div>
    </div>

    <div
      class="rounded-3xl border border-[#f3d5dd] bg-white/85 p-4 shadow-[0_24px_70px_rgba(155,51,72,0.12)] backdrop-blur sm:p-5"
    >
      <div class="grid gap-3 sm:grid-cols-2">
        {
          managementAreas.map((area) => (
            <article class="rounded-2xl border border-[#f3d5dd] bg-[#fff9fb] p-4">
              <div class="flex items-center justify-between gap-3">
                <span class="text-xs font-extrabold text-[#8b5d68]">
                  {area.label}
                </span>
                <span
                  class={`rounded-lg px-2 py-1 text-[11px] font-bold ${toneClass[area.tone]}`}
                >
                  فعال
                </span>
              </div>
              <h3 class="mt-3 text-base font-extrabold text-[#3f2730]">
                {area.value}
              </h3>
              <p class="mt-2 text-xs leading-6 text-[#765964]">{area.detail}</p>
            </article>
          ))
        }
      </div>

      <div class="mt-5 rounded-2xl border border-[#f3d5dd] bg-white p-4">
        <p class="text-sm font-extrabold text-[#3f2730]">مسیر درخواست نوبت</p>
        <ol class="mt-4 space-y-3">
          {
            requestFlow.map((step, index) => (
              <li class="flex gap-3">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#c3425b] text-xs font-extrabold text-white">
                  {index + 1}
                </span>
                <span>
                  <strong class="block text-sm text-[#3f2730]">
                    {step.title}
                  </strong>
                  <span class="mt-1 block text-xs leading-6 text-[#765964]">
                    {step.text}
                  </span>
                </span>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>
