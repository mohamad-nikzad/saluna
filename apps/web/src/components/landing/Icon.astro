---
import { icons, type IconName } from './icons'

interface Props {
  name: IconName
  class?: string
}

const { name, class: className = 'h-6 w-6' } = Astro.props
const elements = icons[name]
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {
    elements.map(([tag, attrs]) => {
      if (tag === 'path') return <path d={attrs.d} />
      if (tag === 'circle')
        return <circle cx={attrs.cx} cy={attrs.cy} r={attrs.r} />
      if (tag === 'rect') return <rect {...attrs} />
      if (tag === 'line')
        return <line x1={attrs.x1} x2={attrs.x2} y1={attrs.y1} y2={attrs.y2} />
    })
  }
</svg>
