---
import { brand } from '@repo/brand'
import { displayClass } from '@/content/landing'
import { publicNavLinks, publicSiteInfo } from '@/content/public-site'
import Icon from './Icon.astro'

const brandFa = brand.name.fa
---

<footer class="border-t border-[#f3d5dd] bg-white/60 px-5 py-8 sm:px-8">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-5 lg:flex-row"
  >
    <div class="flex items-center gap-2.5">
      <img
        src="/landing/saloora-mark.png"
        alt=""
        width="32"
        height="32"
        decoding="async"
        class="h-8 w-8"
      />
      <span class={`${displayClass} text-xl text-[#7a2a40]`}>{brandFa}</span>
    </div>

    <nav class="flex flex-wrap justify-center gap-x-5 gap-y-2 text-xs text-[#8b6b73]">
      {
        publicNavLinks.map((link) => (
          <a href={link.href} class="transition hover:text-[#7a2a40]">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex flex-col items-center gap-2 text-xs text-[#8b6b73] sm:flex-row">
      <p>© ۱۴۰۵ {brandFa}. تمام حقوق محفوظ است.</p>
      <span class="hidden sm:inline">|</span>
      <div class="flex items-center gap-1.5">
        <Icon name="wallet" class="h-3.5 w-3.5" />
        <span>
          {publicSiteInfo.operatorName}، {publicSiteInfo.location}
        </span>
      </div>
    </div>
  </div>
</footer>
