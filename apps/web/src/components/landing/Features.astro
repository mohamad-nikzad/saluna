---
import { brand } from '@repo/brand'
import type { Feature } from '@/content/landing'
import { displayClass } from '@/content/landing'
import Icon from './Icon.astro'

const brandFa = brand.name.fa

interface Props {
  features: Feature[]
}

const { features } = Astro.props
---

<section id="features" class="relative px-5 py-20 sm:px-8 sm:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-extrabold text-[#9b3348]">امکانات فعلی {brandFa}</p>
      <h2 class={`${displayClass} mt-3 text-3xl leading-tight text-[#3f2730] sm:text-5xl`}>
        ابزارهای اصلی مدیریت سالن در یک پنل
      </h2>
      <p class="mt-4 text-base leading-8 text-[#6b4955]">
        این بخش‌ها بر اساس قابلیت‌هایی نوشته شده‌اند که امروز در محصول وجود دارند؛ نه
        وعده‌های آینده.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <article class="group rounded-2xl border border-[#f3d5dd] bg-white/80 p-6 shadow-[0_18px_50px_rgba(155,51,72,0.06)] backdrop-blur transition hover:-translate-y-1 hover:border-[#e8a8ba] hover:shadow-[0_24px_60px_rgba(155,51,72,0.12)]">
            <div class="mb-5 grid h-12 w-12 place-items-center rounded-xl bg-gradient-to-br from-[#fde2e9] to-[#f5b6c6] text-[#9b2f4a] transition group-hover:from-[#9b2f4a] group-hover:to-[#c3425b] group-hover:text-white">
              <Icon name={feature.icon} class="h-6 w-6" />
            </div>
            <h3 class="text-lg font-extrabold text-[#3f2730]">{feature.title}</h3>
            <p class="mt-3 text-sm leading-7 text-[#6b4955]">{feature.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
