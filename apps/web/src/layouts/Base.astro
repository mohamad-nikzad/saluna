---
import '../styles/globals.css'
import { Font } from 'astro:assets'
import Head from '../components/Head.astro'

interface Props {
  title: string
  description?: string
  canonical?: string
  ogImage?: string
  jsonLd?: unknown | unknown[]
  preloadLalezar?: boolean
}

const { title, description, canonical, ogImage, jsonLd, preloadLalezar = false } =
  Astro.props
---

<html lang="fa" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-vazirmatn" preload />
    {preloadLalezar ? <Font cssVariable="--font-lalezar" preload /> : null}
    <Head
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      jsonLd={jsonLd}
    />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
