---
export const prerender = true

import Base from '@/layouts/Base.astro'
import Hero from '@/components/landing/Hero.astro'
import Features from '@/components/landing/Features.astro'
import DashboardPreview from '@/components/landing/DashboardPreview.astro'
import Testimonials from '@/components/landing/Testimonials.astro'
import Cta from '@/components/landing/Cta.astro'
import Footer from '@/components/landing/Footer.astro'
import {
  features,
  stats,
  testimonials,
  dashboardMetrics,
  upcomingAppointments,
  popularServices,
  loginHref,
  signupHref,
} from '@/content/landing'

const title = 'سالورا | مدیریت هوشمند سالن زیبایی'
const description =
  'سالورا نرم‌افزار مدیریت نوبت‌ها، مشتریان، خدمات و پرسنل برای سالن‌های زیبایی است.'
const canonical = new URL('/', Astro.site ?? Astro.url.origin).toString()
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  preloadLalezar={true}
>
  <main
    dir="rtl"
    class="saloora-landing relative box-border min-h-dvh overflow-hidden bg-[#fdf5f8] text-[#3f2730]"
  >
    <style>
      .saloora-landing {
        max-width: 100%;
        overflow-x: hidden;
      }
    </style>

    <Hero loginHref={loginHref} signupHref={signupHref} />
    <Features features={features} />
    <DashboardPreview
      dashboardMetrics={dashboardMetrics}
      upcomingAppointments={upcomingAppointments}
      popularServices={popularServices}
      stats={stats}
    />
    <Testimonials testimonials={testimonials} />
    <Cta loginHref={loginHref} signupHref={signupHref} />
    <Footer />
  </main>
</Base>
