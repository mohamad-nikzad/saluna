---
export const prerender = true

import PublicInfoLayout from '@/layouts/PublicInfoLayout.astro'
import { displayClass } from '@/content/landing'
import { publicServiceItems, publicSiteInfo } from '@/content/public-site'

const title = `خدمات و امکانات | ${publicSiteInfo.brandName}`
const description = `معرفی خدمات و امکانات ${publicSiteInfo.brandName}: مدیریت نوبت‌ها، مشتریان، خدمات سالن، پرسنل، صفحه عمومی سالن و پیامک تایید.`
const canonical = new URL('/services', Astro.url.origin).toString()
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `نرم‌افزار مدیریت سالن زیبایی ${publicSiteInfo.brandName}`,
  provider: {
    '@type': 'Organization',
    name: publicSiteInfo.operatorName,
  },
  areaServed: 'IR',
  serviceType: 'Salon management software',
  description,
}
---

<PublicInfoLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="px-5 py-16 sm:px-8 sm:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-sm font-extrabold text-[#9b3348]">خدمات و امکانات</p>
        <h1 class={`${displayClass} mt-3 break-words text-4xl leading-tight text-[#3f2730] sm:text-5xl`}>
          امکانات نرم‌افزاری برای مدیریت سالن
        </h1>
        <p class="mt-6 text-base leading-8 text-[#6b4955]">
          منظور از خدمات در {publicSiteInfo.brandName}، امکانات نرم‌افزاری برای مدیر
          سالن است. این محصول خدمات آرایشی ارائه نمی‌کند؛ بلکه ابزار مدیریت، ثبت و
          پیگیری کارهای سالن را فراهم می‌کند.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          publicServiceItems.map((item) => (
            <article class="rounded-2xl border border-[#f3d5dd] bg-white/80 p-6 shadow-[0_18px_50px_rgba(155,51,72,0.06)]">
              <h2 class="text-lg font-extrabold text-[#3f2730]">{item.title}</h2>
              <p class="mt-3 text-sm leading-7 text-[#6b4955]">{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</PublicInfoLayout>
