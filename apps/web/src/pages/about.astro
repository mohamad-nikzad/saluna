---
export const prerender = true

import PublicInfoLayout from '@/layouts/PublicInfoLayout.astro'
import { displayClass } from '@/content/landing'
import { publicSiteInfo } from '@/content/public-site'

const title = `درباره ما | ${publicSiteInfo.brandName}`
const description = `${publicSiteInfo.brandName} نرم‌افزار مدیریت سالن زیبایی است که توسط ${publicSiteInfo.operatorName} از ${publicSiteInfo.location} توسعه داده می‌شود.`
const canonical = new URL('/about', Astro.url.origin).toString()
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: publicSiteInfo.brandName,
  url: new URL('/', Astro.url.origin).toString(),
  areaServed: 'IR',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Tehran',
    addressCountry: 'IR',
  },
  contactPoint: publicSiteInfo.contact.phone
    ? {
        '@type': 'ContactPoint',
        telephone: publicSiteInfo.contact.phone,
        contactType: 'customer support',
        areaServed: 'IR',
        availableLanguage: ['fa'],
      }
    : undefined,
}
---

<PublicInfoLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="px-5 py-16 sm:px-8 sm:py-20">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="text-sm font-extrabold text-[#9b3348]">درباره ما</p>
        <h1 class={`${displayClass} mt-3 break-words text-4xl leading-tight text-[#3f2730] sm:text-5xl`}>
          سالونا برای نظم روزانه سالن‌های زیبایی ساخته می‌شود
        </h1>
        <p class="mt-6 text-base leading-8 text-[#6b4955]">
          {publicSiteInfo.brandName} یک نرم‌افزار فارسی برای مدیریت سالن زیبایی است.
          تمرکز محصول روی نوبت‌ها، مشتریان، پرسنل، خدمات، صفحه عمومی سالن و درخواست
          نوبت است تا مدیر سالن بتواند کارهای روزانه را در یک مسیر منظم پیگیری کند.
        </p>
      </div>

      <div class="rounded-2xl border border-[#f3d5dd] bg-white/80 p-6 shadow-[0_18px_50px_rgba(155,51,72,0.06)]">
        <dl class="grid gap-5 sm:grid-cols-2">
          <div>
            <dt class="text-xs font-bold text-[#9b3348]">نام محصول</dt>
            <dd class="mt-2 text-lg font-extrabold text-[#3f2730]">{publicSiteInfo.brandName}</dd>
          </div>
          <div>
            <dt class="text-xs font-bold text-[#9b3348]">ارائه‌دهنده</dt>
            <dd class="mt-2 text-lg font-extrabold text-[#3f2730]">{publicSiteInfo.operatorName}</dd>
          </div>
          <div>
            <dt class="text-xs font-bold text-[#9b3348]">موقعیت</dt>
            <dd class="mt-2 text-lg font-extrabold text-[#3f2730]">{publicSiteInfo.location}</dd>
          </div>
          <div>
            <dt class="text-xs font-bold text-[#9b3348]">وضعیت دسترسی</dt>
            <dd class="mt-2 text-lg font-extrabold text-[#3f2730]">{publicSiteInfo.availability}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="px-5 pb-20 sm:px-8">
    <div class="mx-auto grid max-w-7xl gap-4 md:grid-cols-3">
      <article class="rounded-2xl border border-[#f3d5dd] bg-white/70 p-6">
        <h2 class="text-lg font-extrabold text-[#3f2730]">ماموریت</h2>
        <p class="mt-3 text-sm leading-7 text-[#6b4955]">
          ساده‌تر کردن مدیریت نوبت، مشتری، پرسنل و خدمات برای سالن‌هایی که می‌خواهند
          اطلاعاتشان پراکنده نباشد.
        </p>
      </article>
      <article class="rounded-2xl border border-[#f3d5dd] bg-white/70 p-6">
        <h2 class="text-lg font-extrabold text-[#3f2730]">رویکرد</h2>
        <p class="mt-3 text-sm leading-7 text-[#6b4955]">
          قابلیت‌ها مرحله‌به‌مرحله و بر اساس نیاز واقعی سالن‌ها توسعه داده می‌شوند.
        </p>
      </article>
      <article class="rounded-2xl border border-[#f3d5dd] bg-white/70 p-6">
        <h2 class="text-lg font-extrabold text-[#3f2730]">مخاطب</h2>
        <p class="mt-3 text-sm leading-7 text-[#6b4955]">
          مدیران سالن‌های زیبایی، ناخن، مو، پوست، مژه، ابرو و اسپا در ایران.
        </p>
      </article>
    </div>
  </section>
</PublicInfoLayout>
