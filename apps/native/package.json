{
  "name": "@repo/native",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start": "expo start",
    "dev": "expo start",
    "dev:prod-api": "EXPO_PUBLIC_API_BASE_URL=https://aravira-saloon.vercel.app EXPO_PUBLIC_WEB_BASE_URL=https://aravira-saloon.vercel.app expo start --port 8081",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\" && pnpm style:check",
    "style:check": "node scripts/check-style-guardrails.mjs",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write"
  },
  "dependencies": {
    "@expo-google-fonts/vazirmatn": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@repo/api-client": "workspace:*",
    "@repo/brand-tokens": "workspace:*",
    "@repo/salon-core": "workspace:*",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.0",
    "expo-image": "~3.0.0",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.8",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "typescript": "~5.9.2"
  }
}
