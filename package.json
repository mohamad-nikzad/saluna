{
  "name": "aravira-saloon",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev --filter=@repo/pwa --filter=@repo/web --filter=@repo/api",
    "dev:web-stack": "turbo run dev:local --filter=@repo/web --filter=@repo/api",
    "dev:app": "pnpm --filter @repo/app dev",
    "dev:web": "pnpm --filter @repo/web dev",
    "dev:web-next": "pnpm --filter @repo/web-next dev",
    "smoke:web": "node scripts/smoke-web.mjs",
    "fonts:web": "node scripts/fetch-web-fonts.mjs",
    "dev:api": "pnpm --filter @repo/api dev",
    "dev:hono": "turbo run dev:hono --filter=@repo/api --filter=@repo/app",
    "dev:native": "pnpm --filter @repo/native dev",
    "dev:native:prod-api": "pnpm --filter @repo/native dev:prod-api",
    "dev:mobile": "node scripts/dev-mobile.mjs",
    "dev:local": "turbo run dev:local --filter=@repo/pwa --filter=@repo/web --filter=@repo/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e --filter=@repo/app",
    "boundaries": "turbo run boundaries",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,mjs,json,md,css}\"",
    "tokens:generate": "pnpm --filter @repo/brand-tokens tokens:generate",
    "tokens:check": "pnpm --filter @repo/brand-tokens tokens:check",
    "db:generate": "DATABASE_ENV_FILE=.env.database.dev pnpm --filter @repo/database db:generate",
    "db:check": "node scripts/check-db-schema-sync.mjs",
    "db:migrate": "sh -c 'DATABASE_ENV_FILE=\"${DATABASE_ENV_FILE:-.env.database.dev}\" pnpm --filter @repo/database db:migrate'",
    "db:migrate:main": "DATABASE_ENV_FILE=.env.database.main pnpm --filter @repo/database db:migrate",
    "db:push": "DATABASE_ENV_FILE=.env.database.dev pnpm --filter @repo/database db:push",
    "db:push:main": "DATABASE_ENV_FILE=.env.database.main pnpm --filter @repo/database db:push",
    "db:studio": "DATABASE_ENV_FILE=.env.database.dev pnpm --filter @repo/database db:studio",
    "db:studio:main": "DATABASE_ENV_FILE=.env.database.main pnpm --filter @repo/database db:studio",
    "db:seed": "DATABASE_ENV_FILE=.env.database.dev pnpm --filter @repo/database db:seed",
    "db:seed:main": "DATABASE_ENV_FILE=.env.database.main pnpm --filter @repo/database db:seed",
    "db:generate:local": "DATABASE_ENV_FILE=.env.database.local pnpm --filter @repo/database db:generate",
    "db:migrate:local": "DATABASE_ENV_FILE=.env.database.local pnpm --filter @repo/database db:migrate",
    "db:prepare:local": "node scripts/db-migrate-local.mjs",
    "db:reconcile:local": "node scripts/reconcile-local-migrations.mjs",
    "db:push:local": "DATABASE_ENV_FILE=.env.database.local pnpm --filter @repo/database db:push",
    "db:studio:local": "DATABASE_ENV_FILE=.env.database.local pnpm --filter @repo/database db:studio",
    "db:seed:local": "DATABASE_ENV_FILE=.env.database.local pnpm --filter @repo/database db:seed",
    "brand:icons": "node scripts/generate-saloora-icons.mjs",
    "bench:local": "BASE_URL=http://localhost:3000 ./benchmarks/run.sh",
    "bench:prod": "BASE_URL=https://aravira-saloon.vercel.app ./benchmarks/run.sh",
    "bench:local:compare": "./benchmarks/run-compare.sh",
    "bench:summary": "node benchmarks/summarize.mjs",
    "bench:compare": "node benchmarks/compare.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@repo/eslint-config": "workspace:*",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "pwa-asset-generator": "^8.1.4",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.5.8",
    "typescript": "5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
