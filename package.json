{
  "name": "saluna",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev --filter=@repo/pwa --filter=@repo/web --filter=@repo/admin --filter=@repo/api",
    "dev:web-stack": "turbo run dev --filter=@repo/web --filter=@repo/api",
    "dev:web": "turbo run dev --filter=@repo/web --filter=@repo/api",
    "dev:pwa": "turbo run dev --filter=@repo/pwa --filter=@repo/api",
    "dev:admin": "turbo run dev --filter=@repo/admin --filter=@repo/api",
    "smoke:web": "node scripts/smoke-web.mjs",
    "fonts:web": "node scripts/fetch-web-fonts.mjs",
    "dev:api": "pnpm --filter @repo/api dev",
    "dev:pwa-lan": "node scripts/dev-pwa-lan.mjs",
    "dev:admin-stack": "turbo run dev --filter=@repo/api --filter=@repo/admin",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "playwright test",
    "perf:pwa-overlay": "tsx scripts/profile-pwa-overlay.ts",
    "boundaries": "turbo run boundaries",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,mjs,json,md,css}\"",
    "tokens:generate": "pnpm --filter @repo/brand-tokens tokens:generate",
    "tokens:check": "pnpm --filter @repo/brand-tokens tokens:check",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:check": "node scripts/check-db-schema-sync.mjs",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:prepare": "node scripts/db-prepare.mjs",
    "db:reconcile": "node scripts/reconcile-migrations.mjs",
    "db:seed:catalog-presets": "pnpm --filter @repo/database db:seed:catalog-presets",
    "brand:icons": "node scripts/generate-saluna-icons.mjs",
    "brand:sync": "tsx scripts/sync-brand-static.mjs",
    "bench:local": "BASE_URL=http://localhost:3000 ./benchmarks/run.sh",
    "bench:prod": "BASE_URL=https://saluna.vercel.app ./benchmarks/run.sh",
    "bench:summary": "node benchmarks/summarize.mjs",
    "bench:compare": "node benchmarks/compare.mjs",
    "generate:api-contract": "pnpm --filter @repo/api generate:openapi",
    "generate:api-client": "pnpm --filter @repo/api-client generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@repo/auth": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/salon-core": "workspace:*",
    "drizzle-kit": "^0.30.4",
    "drizzle-orm": "^0.39.3",
    "eslint": "^9",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "pwa-asset-generator": "^8.1.4",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "turbo": "^2.5.8",
    "typescript": "5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "zod": "4.4.3"
    }
  }
}
