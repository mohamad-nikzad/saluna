# Copy to .env.production on the build machine and VPS. Never commit the real file.

# Image/version knobs. SALUNA_IMAGE_TAG remains the shared fallback for legacy
# tarball releases. Set per-app tags for independent registry deploys.
SALUNA_IMAGE_TAG=2026-06-03-1
SALUNA_API_VERSION=0.7.0
SALUNA_API_IMAGE_TAG=
SALUNA_API_IMAGE_REGISTRY=
SALUNA_WEB_VERSION=0.4.0
SALUNA_WEB_IMAGE_TAG=
SALUNA_WEB_IMAGE_REGISTRY=
SALUNA_PWA_VERSION=0.7.0
SALUNA_PWA_IMAGE_TAG=
SALUNA_PWA_IMAGE_REGISTRY=
# VPS is linux/amd64. Override only if deploying to a different CPU architecture.
DOCKER_PLATFORM=linux/amd64
# Default registry used by legacy and HamGit deploys. Per-app registry values
# above are persisted automatically when another pipeline (such as GitHub)
# deploys an app from a different registry.
# Set to 127.0.0.1:5000/ for the VPS-local registry workflow, or
# registry.hamdocker.ir/<namespace>/ for registry-first deploys.
SALUNA_IMAGE_REGISTRY=
# Optional Docker build mirrors. Leave blank for normal connected local builds.
# Set these in HamGit/Hamravesh CI or on an Iranian-only VPS builder.
SALUNA_NODE_IMAGE=
SALUNA_NGINX_IMAGE=
SALUNA_ALPINE_MIRROR=
SALUNA_NPM_REGISTRY=
SALUNA_PNPM_VERSION=9.15.9
REGISTRY_PORT=5000
HTTP_PORT=80
HTTPS_PORT=443

# Domains routed by deploy/nginx/templates/saluna.conf.template.
PUBLIC_DOMAIN=saluna.ir
APP_DOMAIN=app.saluna.ir
API_DOMAIN=api.saluna.ir

# Public origins baked into app builds and used at runtime.
PUBLIC_APP_URL=https://saluna.ir
PUBLIC_API_URL=https://api.saluna.ir
PUBLIC_MANAGER_APP_URL=https://app.saluna.ir
NEXT_PUBLIC_APP_URL=https://saluna.ir
NEXT_PUBLIC_API_URL=https://api.saluna.ir
VITE_API_BASE_URL=https://api.saluna.ir
VITE_APP_URL=https://app.saluna.ir
VITE_WEB_URL=https://saluna.ir
VITE_PWA_ASSET_VERSION=2026-06-03-1

# Internal Postgres. Keep DATABASE_URL values aligned with POSTGRES_*.
POSTGRES_DB=saluna
POSTGRES_USER=saluna
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://saluna:replace-with-a-long-random-password@postgres:5432/saluna
DATABASE_URL_DIRECT=postgresql://saluna:replace-with-a-long-random-password@postgres:5432/saluna

# API/auth. Generate secrets with:
# openssl rand -base64 32
JWT_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=https://api.saluna.ir
PWA_ORIGIN=https://app.saluna.ir
ADMIN_ORIGIN=https://admin.saluna.ir
CORS_ORIGINS=https://app.saluna.ir,https://admin.saluna.ir,https://saluna.ir,https://www.saluna.ir

# Web push. Optional until push is enabled.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@saluna.ir

# SMS. Disabled until sms.ir credentials and templates are set.
SMS_ENABLED=false
SMS_PROVIDER=sms_ir
SMS_IR_API_KEY=
SMS_IR_LINE_NUMBER=
SMS_IR_OTP_TEMPLATE_ID=
SMS_IR_API_BASE_URL=https://api.sms.ir/v1
SMS_IR_LOGIN_TEMPLATE_ID=
SMS_IR_SIGNUP_TEMPLATE_ID=
SMS_IR_FORGOT_PASSWORD_TEMPLATE_ID=
SMS_IR_APPOINTMENT_REQUEST_TEMPLATE_ID=

# Telegram messaging. Disabled until bot credentials and HTTPS webhook are ready.
PUBLIC_APP_BASE_URL=https://app.saluna.ir
MESSAGING_PWA_BASE_URL=https://app.saluna.ir
MESSAGING_LINK_TOKEN_TTL_MINUTES=15
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=salunabot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://api.saluna.ir/api/v1/messaging/telegram/webhook
