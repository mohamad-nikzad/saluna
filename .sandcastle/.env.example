# Cursor auth for Sandcastle sandboxes.
#
# Preferred for this repo: session auth from the host Keychain.
#   pnpm sandcastle:sync-cursor-auth
# That writes .sandcastle/cursor-auth/auth.json (gitignored) and clears any
# mistaken CURSOR_API_KEY value.
#
# Optional alternative: a real dashboard API key (not a Keychain JWT):
#   CURSOR_API_KEY=key_...
CURSOR_API_KEY=
AGENT_CLI_CREDENTIAL_STORE=file
