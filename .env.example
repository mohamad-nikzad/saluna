# --- Split local targets (recommended for Neon branches) ---
# Put JWT / VAPID / other secrets in `.env.local` (gitignored).
# Put only database URLs in `.env.database.dev`, `.env.database.multitenant`,
# and `.env.database.main` (gitignored).
# Bun loads `.env.local` first, then the database file, so the latter wins for DATABASE_*.
#
#   bun run dev                 → Neon dev branch (.env.database.dev)
#   bun run dev:multitenant     → Neon multitenant branch (.env.database.multitenant)
#   bun run dev:main            → Neon production branch (.env.database.main)
#   bun run db:migrate          → run checked-in migrations on dev branch
#   bun run db:migrate:multitenant → run checked-in migrations on multitenant branch
#   bun run db:migrate:main     → run checked-in migrations on production (use with care)
#
# Create each database file from Neon:
# pooled connection string → DATABASE_URL
# direct connection string → DATABASE_URL_DIRECT

# --- Single-file setup (simplest if you only have one database) ---
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/salon
# DATABASE_URL_DIRECT=postgresql://postgres:postgres@127.0.0.1:5432/salon

# Public marketing + booking site (apps/web, Astro).
PUBLIC_APP_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002

# Strong secret in production (legacy JWT auth)
JWT_SECRET=change-me-in-production

# Better Auth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-min-32-chars-in-production
BETTER_AUTH_URL=http://localhost:3002
# Origin of the PWA SPA, allowed for cross-origin cookie sessions / CSRF.
PWA_ORIGIN=http://localhost:3000
# Origin of the internal admin SPA, allowed for Better Auth cookie sessions / CSRF.
ADMIN_ORIGIN=http://localhost:3003

# Web Push (VAPID). Generate with: bunx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL (see web-push docs).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# SMS notifications are adapter-backed and disabled until sms.ir credentials are set.
SMS_ENABLED=false
SMS_PROVIDER=sms_ir
SMS_IR_API_KEY=
SMS_IR_LINE_NUMBER=
# sms.ir sandbox default verify template is 123456.
SMS_IR_OTP_TEMPLATE_ID=
# Must match the sms.ir approved template variable name without #...#.
SMS_IR_OTP_PARAMETER_NAME=Code
SMS_IR_API_BASE_URL=https://api.sms.ir/v1
SMS_IR_LOGIN_TEMPLATE_ID=
SMS_IR_SIGNUP_TEMPLATE_ID=
SMS_IR_FORGOT_PASSWORD_TEMPLATE_ID=
SMS_IR_APPOINTMENT_REQUEST_TEMPLATE_ID=

# Messaging providers (Telegram in Phase 1). Required only when _ENABLED=true.
# Absolute origin of the manager app, used to build deep links inside chat
# messages (e.g. https://app.saluna.ir). No trailing slash.
# Required when TELEGRAM_ENABLED=true.
PUBLIC_APP_BASE_URL=
# Optional HTTPS origin for Telegram inline links and the Web App menu button.
# Use when PUBLIC_APP_BASE_URL is http://localhost (Telegram requires HTTPS).
# Example local: https://<your-ngrok>.ngrok-free.app
MESSAGING_PWA_BASE_URL=

# Link tokens expire after this many minutes. 15 is the recommended default.
MESSAGING_LINK_TOKEN_TTL_MINUTES=15

# Telegram bot — created via @BotFather. After setting these, run
# `pnpm --filter @repo/api cli:messaging-set-webhook` to register the webhook
# with Telegram. Rotate TELEGRAM_WEBHOOK_SECRET as needed; re-run the CLI.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=salunabot
# 1–256 chars: A–Z, a–z, 0–9, underscore, hyphen only (Telegram Bot API).
# Example: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=
# Public URL where Telegram POSTs updates, e.g.
# https://api.saluna.ir/api/v1/messaging/telegram/webhook
TELEGRAM_WEBHOOK_URL=


BALE_ENABLED=false
BALE_BOT_TOKEN=
BALE_BOT_USERNAME=
BALE_WEBHOOK_SECRET=
BALE_WEBHOOK_URL=

# Optional: only needed for Safir phone delivery
BALE_SAFIR_ENABLED=false
BALE_SAFIR_API_ACCESS_KEY=
BALE_SAFIR_BOT_ID=

PUBLIC_APP_BASE_URL=http://localhost:3000
MESSAGING_LINK_TOKEN_TTL_MINUTES=15
