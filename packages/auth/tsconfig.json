{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/salon-core": ["../salon-core/src/index.ts"],
      "@repo/salon-core/*": ["../salon-core/src/*"],
      "@repo/database": ["../database/src/index.ts"],
      "@repo/database/*": ["../database/src/*"],
      "@repo/notifications": ["../notifications/src/index.ts"],
      "@repo/notifications/*": ["../notifications/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "src/auth.ts",
    "src/auth.test.ts",
    "src/auth-next.ts",
    "src/tenant-next.ts",
    "src/signup.ts"
  ]
}
