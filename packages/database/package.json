{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./appointments": "./src/appointments.ts",
    "./auth-users": "./src/auth-users.ts",
    "./members": "./src/internal/member-queries.ts",
    "./clients": "./src/clients.ts",
    "./commissions": "./src/commissions.ts",
    "./dashboard": "./src/dashboard.ts",
    "./onboarding": "./src/onboarding.ts",
    "./notifications": "./src/notifications.ts",
    "./messaging": "./src/messaging.ts",
    "./push": "./src/push.ts",
    "./retention": "./src/retention.ts",
    "./catalog-presets": "./src/catalog-presets.ts",
    "./services": "./src/services.ts",
    "./settings": "./src/settings.ts",
    "./staff": "./src/staff.ts",
    "./salon-profile": "./src/salon-profile.ts",
    "./salon-handoff": "./src/salon-handoff.ts",
    "./public": "./src/public.ts",
    "./appointment-requests": "./src/appointment-requests.ts",
    "./rate-limit": "./src/rate-limit.ts",
    "./admin": "./src/admin.ts",
    "./support-tickets": "./src/support-tickets.ts",
    "./client": "./src/client.ts",
    "./config": "./src/config.ts",
    "./auth-password": "./src/auth-password.ts",
    "./keys": "./src/keys.ts",
    "./seed/catalog-presets": "./src/seed/catalog-presets.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "boundaries": "eslint . --max-warnings=0",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:seed:catalog-presets": "tsx src/seed/catalog-presets-only.ts",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "RUN_DATABASE_INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "test:integration:support": "RUN_DATABASE_INTEGRATION=1 vitest run --config vitest.integration.config.ts src/internal/support-ticket-queries.integration.test.ts"
  },
  "dependencies": {
    "@repo/salon-core": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22"
  }
}
