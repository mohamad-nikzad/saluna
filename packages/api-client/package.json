    "./legacy": "./src/legacy/index.ts",
    "./auth": "./src/legacy/auth.ts",
    "./errors": "./src/errors.ts",
    "./generated-client": "./src/client.ts",
    "./sdk": "./src/generated/sdk.gen.ts",
